<?xml version="1.0" encoding="utf-8"?>
<GridLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="3"
    android:rowCount="4"
    android:layout_marginTop="16dp"
    android:padding="8dp">

    <!-- Row 1: 1 2 3 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey1"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="1" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey2"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="2" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey3"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="3" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Row 2: 4 5 6 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey4"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="4" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey5"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="5" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey6"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="6" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Row 3: 7 8 9 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey7"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="7" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey8"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="8" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey9"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:layout_marginBottom="6dp"
        android:text="9" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <!-- Row 4: ← 0 ✓ -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKeyBackspace"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp"
        android:text="⌫" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#757575"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKey0"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp"
        android:text="0" android:textSize="22sp"
        app:strokeColor="#CCCCCC" android:textColor="#212121"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnKeyConfirm"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_columnWeight="1"
        android:layout_marginStart="4dp" android:layout_marginEnd="4dp"
        android:text="✓" android:textSize="22sp"
        android:backgroundTint="#1B5E20"
        android:textColor="@android:color/white"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>

</GridLayout>
